# ─────────────────────────────────────────────────────────────────────────────
# Backend environment variables (Crypto Lead Extraction Platform)
#
# Copy to `.env` for local use. NONE of these are secrets — the backend uses
# only public web scraping and requires no API keys or credentials.
# `.env` is gitignored and must never be committed.
# ─────────────────────────────────────────────────────────────────────────────

# HTTP port for the FastAPI/uvicorn server.
# On Render this is injected automatically; only set it for local/self-hosted.
PORT=8000

# ─── CLI-only (running `python main.py` directly) ────────────────────────────
# The backend sets these automatically when it spawns an extraction subprocess,
# so you only need them when invoking the CLI yourself.

# Listing/category URL to extract from (alternative to passing it as argv[1]).
# Examples:
#   https://coinmarketcap.com/view/layer-1/
#   https://www.coingecko.com/en/categories/artificial-intelligence
#   https://coinranking.com/coins/new
#   https://defillama.com/raises
# PLATFORM_URL=

# Max number of leads to enrich (omit / blank = all collected projects).
# LEAD_LIMIT=25

# Extraction mode: "ranked" (top by market cap / amount raised) or "recent" (newest).
# EXTRACT_MODE=ranked

# Parallel enrichment workers (1–8). Each worker runs its own Chromium instance
# (~200–300 MB RAM). 3 is a safe default for a 2 GB server.
# WORKERS=3
